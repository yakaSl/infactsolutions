# Copy this file to `.env` and fill in real values for local development.
# `.env` is git-ignored; this `.env.example` is committed, so NEVER put real
# secrets here — placeholders only.
#
# In production (Firebase App Hosting) these are provided via apphosting.yaml:
# non-sensitive vars as plain `value:` entries, and the ones marked "SECRET"
# below via Cloud Secret Manager (`firebase apphosting:secrets:set <NAME>`).

# --- General ---
# Email address that receives contact, donation, and investment notifications.
ADMIN_NOTIFICATION_EMAIL=hello@example.com

# Public base URL of the site. Used to build PayPal return/cancel URLs.
# Local dev: http://localhost:9002
NEXT_PUBLIC_BASE_URL=https://example.com

# --- Resend (transactional email) ---
# Sign up at https://resend.com, create an API key, verify your sender domain.
# SECRET (prod: Cloud Secret Manager)
RESEND_API_KEY=re_your_resend_api_key
# Verified sender address.
RESEND_FROM=Your Brand <noreply@example.com>

# --- Firebase Admin (Firestore) ---
# Single-line JSON of a service-account key.
# Firebase console: Project settings -> Service accounts -> Generate new private key,
# then JSON-stringify onto one line.
# SECRET (prod: Cloud Secret Manager)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# --- Firebase Web (client-side Analytics) ---
# Public Web app config from Firebase console:
# Project settings -> General -> Your apps -> Web app -> "SDK setup and configuration".
# These are NEXT_PUBLIC_ (inlined at build time) and safe to expose in the browser —
# Firebase Web API keys are public identifiers, not secrets.
# Analytics only initializes when NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID is set.
NEXT_PUBLIC_FIREBASE_API_KEY=your_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- PayPal (donations) ---
# Sandbox: https://api-m.sandbox.paypal.com  |  Live: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# App credentials from https://developer.paypal.com (Apps & Credentials).
# SECRET (prod: Cloud Secret Manager)
PAYPAL_CLIENT_ID=your_paypal_client_id
# SECRET (prod: Cloud Secret Manager)
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Webhook ID returned by PayPal when you register the webhook URL
# (POST /api/paypal/webhook). SECRET (prod: Cloud Secret Manager)
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

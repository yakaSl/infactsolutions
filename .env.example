# Email address that receives contact, donation, and investment notifications.
ADMIN_NOTIFICATION_EMAIL=hello@infactsolutions.net

# Public base URL for the deployed site. Used to build PayPal return/cancel URLs.
# In local dev: http://localhost:9002
NEXT_PUBLIC_BASE_URL=https://infactsolutions.net

# --- Resend (transactional email) ---
# Sign up at https://resend.com, create an API key, verify your sender domain.
RESEND_API_KEY=re_VGfxoC11_9MauwhpzAm56paAsnGv91wE5
# Verified sender address, e.g. "Infact Solutions <noreply@infactsolutions.net>"
RESEND_FROM=

# --- Firebase Admin (Firestore) ---
# Single-line JSON of a service-account key.
# In Firebase console: Project settings -> Service accounts -> Generate new private key.
# Then JSON-stringify and put on one line, e.g. {"type":"service_account",...}.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- PayPal (donations) ---
